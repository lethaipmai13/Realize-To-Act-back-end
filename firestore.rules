rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.type in ['school', 'community-partner'];
    }

    function isValidConnection(data) {
      return data.fromId is string && data.toId is string &&
             data.status in ['pending', 'approved', 'denied'] &&
             data.item is string && data.item.size() <= 200 &&
             data.quantity is number &&
             data.timestamp is number &&
             data.participants is list && data.participants.size() == 2;
    }

    function isValidChat(data) {
      return data.participants is list && data.participants.size() == 2 &&
             data.participants.hasAll([request.auth.uid]);
    }

    function isValidMessage(data) {
      return data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000 &&
             data.timestamp is string;
    }

    // 3. User Rules
    match /users/{userId} {
      // Public profiles can be read by any signed-in user
      allow read: if isSignedIn();
      // Only the owner can create or update their profile
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'avatar', 'location', 'contactName', 'availability', 
          'dropOffLocation', 'needDropOffAssistance', 'description', 'tags'
        ])
      );
    }

    // 4. Connection Rules
    match /connections/{connId} {
      allow list: if isSignedIn() && resource.data.participants.hasAny([request.auth.uid]);
      allow get: if isSignedIn() && existing().participants.hasAny([request.auth.uid]);
      
      allow create: if isSignedIn() && 
                    isOwner(incoming().fromId) && 
                    isValidConnection(incoming()) && 
                    isValidId(connId);
      
      allow update: if isSignedIn() && (
        // Recipient can update status only
        (isOwner(existing().toId) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Sender can update details if still pending
        (isOwner(existing().fromId) && existing().status == 'pending' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['item', 'quantity', 'description', 'availability']))
      );
      
      allow delete: if isSignedIn() && isOwner(existing().fromId) && existing().status == 'pending';
    }

    // 5. Chat Rules
    match /chats/{chatId} {
      allow list: if isSignedIn() && resource.data.participants.hasAny([request.auth.uid]);
      allow get: if isSignedIn() && existing().participants.hasAny([request.auth.uid]);
      
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isSignedIn() && existing().participants.hasAny([request.auth.uid]) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageTimestamp', 'unreadCount', 'isRecentlyApproved'])
      );

      match /messages/{msgId} {
        allow list, get: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow create: if isSignedIn() && 
                      get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) &&
                      isValidMessage(incoming());
      }
    }

    // 6. Document Rules
    match /documents/{docId} {
      allow list: if isSignedIn() && resource.data.participants.hasAny([request.auth.uid]);
      allow get: if isSignedIn() && existing().participants.hasAny([request.auth.uid]);
      
      allow create: if isSignedIn() && isOwner(incoming().fromId) && incoming().participants.hasAll([incoming().fromId, incoming().toId]);
      allow update: if isSignedIn() && isOwner(existing().toId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'signedDate']);
    }
  }
}
